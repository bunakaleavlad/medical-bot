{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/webhook",
            "dest": "main.py"
        },
        {
            "src": "/",
            "dest": "main.py"
        },
        {
            "src": "/webapps/electrolytes",
            "dest": "/webapps/electrolytes/index.html"
        },
        {
            "src": "/webapps/acidbase",
            "dest": "/webapps/acidbase/index.html"
        },
        {
            "src": "/webapps/infusions",
            "dest": "/webapps/infusions/index.html"
        },
        {
            "src": "/webapps/scales",
            "dest": "/webapps/scales/index.html"
        }
    ]
}
