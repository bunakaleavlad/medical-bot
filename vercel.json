{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/webhook",
            "dest": "main.py"
        },
        {
            "src": "/",
            "dest": "main.py"
        },
        {
            "src": "/webapps/(?<path>.*)/",
            "dest": "/webapps/$path/index.html"
        },
        {
            "src": "/webapps/(.*)",
            "dest": "/webapps/$1"
        }
    ]
}
