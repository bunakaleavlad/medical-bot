{
  "outputDirectory": "webapps",
  "rewrites": [
    {
      "source": "/electrolytes/:path*",
      "destination": "/electrolytes/index.html"
    },
    {
      "source": "/acidbase/:path*",
      "destination": "/acidbase/index.html"
    },
    {
      "source": "/infusions/:path*",
