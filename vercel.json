{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/webhook",
            "dest": "main.py"
        },
        {
            "src": "/",
            "dest": "main.py"
        },
        {
            "src": "/webapps/electrolytes/(.*)",
            "dest": "/webapps/electrolytes/$1"
        },
        {
            "src": "/webapps/acidbase/(.*)",
            "dest": "/webapps/acidbase/$1"
        },
        {
            "src": "/webapps/infusions/(.*)",
            "dest": "/webapps/infusions/$1"
        },
        {
            "src": "/webapps/scales/(.*)",
            "dest": "/webapps/scales/$1"
        }
    ]
}
